---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
const FallbackImage = { src: '/images/hero.jpg' };
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;

// --- SEO: タイトルサフィックスと日英hreflang ---
const path = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const isEnPage = path === '/en/' || path.startsWith('/en/');
const hasBrand = title.includes('The Headquarters');
const fullTitle = hasBrand
	? title
	: isEnPage
		? `${title} | The Headquarters Kobe — Sharehouse in Kobe`
		: `${title}｜神戸のシェアハウス The Headquarters Kobe`;

// 日英対応ページの対応表（ja→en）
const langPairs: Record<string, string> = {
	'/': '/en/',
	'/rooms/': '/en/rooms/',
	'/facilities/': '/en/facilities/',
	'/location/': '/en/location/',
	'/procedures/': '/en/procedures/',
	'/contact/': '/en/contact/',
	'/blog/hq-kobe/': '/en/hq-kobe/',
};
const enToJa: Record<string, string> = Object.fromEntries(
	Object.entries(langPairs).map(([ja, en]) => [en, ja]),
);
const jaPath = langPairs[path] ? path : enToJa[path];
const enPath = langPairs[path] ?? (enToJa[path] ? path : undefined);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" href="/images/logo.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Google Analytics 4 -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-VSH7Z981XF"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag() { dataLayer.push(arguments); }
	gtag('js', new Date());
	gtag('config', 'G-VSH7Z981XF');
</script>

<!-- Microsoft Clarity（ヒートマップ・セッション録画） -->
<script is:inline type="text/javascript">
	(function(c,l,a,r,i,t,y){
		c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
		t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
		y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
	})(window, document, "clarity", "script", "xqy9wgrfmx");
</script>

<!-- 流入元の捕捉（gclid / utm / referrer）: リード経路の特定用 -->
<script is:inline>
	(function () {
		try {
			var KEY = 'hq_attr';
			var a;
			try { a = JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) { a = {}; }
			var p = new URLSearchParams(location.search);
			['gclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach(function (k) {
				var v = p.get(k);
				if (v) a[k] = v;
			});
			if (!a.first_referrer) {
				a.first_referrer = document.referrer || '(direct)';
				a.first_landing = location.pathname + location.search;
				a.first_ts = new Date().toISOString();
			}
			localStorage.setItem(KEY, JSON.stringify(a));
		} catch (e) {}
	})();
</script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang (日英対応ページのみ) -->
{jaPath && enPath && (
	<>
		<link rel="alternate" hreflang="ja" href={new URL(jaPath, Astro.site)} />
		<link rel="alternate" hreflang="en" href={new URL(enPath, Astro.site)} />
		<link rel="alternate" hreflang="x-default" href={new URL(jaPath, Astro.site)} />
	</>
)}

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={isEnPage ? "en_US" : "ja_JP"} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />
