---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'> & { sub?: string };

const { href, sub, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const bulkSlug = pathname.match(/^\/blog\/bulk\/([^/]+)$/)?.[1];
const isActive =
  href === pathname ||
  (bulkSlug !== undefined && href === '/' + bulkSlug);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<span class="main"><slot /></span>
	{sub && <span class="sub">{sub}</span>}
</a>
<style>
	a {
		display: inline-block;
		text-align: center;
		text-decoration: none;
		line-height: 1.2;
	}
	.main {
		display: block;
		font-size: 0.85em;
		font-weight: 600;
	}
	.sub {
		display: block;
		font-size: 0.62em;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	a.active .main {
		font-weight: 700;
	}
	a.active .sub {
		color: var(--accent);
	}
</style>
