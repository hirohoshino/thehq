---
import { getCollection, render } from 'astro:content';
import AvailabilityBanner from '../../components/AvailabilityBanner.astro';
import BlogPost from '../../layouts/BlogPost.astro';

const all = await getCollection('blog');
const post = all.find((p) => p.id === 'en/rooms');
if (!post) throw new Error('en/rooms not found');
const { Content } = await render(post);
---
<BlogPost {...post.data}>
  <AvailabilityBanner lang="en" />
  <Content />
</BlogPost>
