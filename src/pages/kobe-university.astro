---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AvailabilityBanner from '../components/AvailabilityBanner.astro';

const title = '神戸大学の学生に人気のシェアハウス｜The Headquarters Kobe（灘区・水道筋）';
const description =
  '神戸大学へ通える灘区・水道筋のシェアハウス。大学にも三宮にも商店街にも近く、家具付き・月5〜6万円台・初期費用も計5万円、礼金/仲介手数料なし・保証人原則不要。神大生・受験生の一人暮らしに。';

// 神大関連ブログを抽出（優先順）
const entries = await getCollection('blog');
const wanted = [
  '神戸大生に聞いた',
  '神戸大学への通学方法',
  '神大に合格',
  '神戸大学大学院',
  '大学生がシェアハウスに住んで',
];
const relatedPosts = wanted
  .map((kw) => entries.find((e) => e.data.kind === 'post' && (e.data.title ?? '').includes(kw)))
  .filter((e) => e)
  .map((post) => {
    const match = post.body?.match(/!\[.*?\]\((https?:\/\/[^)]+)\)/);
    return { id: post.id, title: post.data.title, img: match ? match[1] : (post.data.coverImage ?? null) };
  });

// FAQ（本文とJSON-LDで共用）
const faqs = [
  { q: 'HQから神戸大学へ通えますか？', a: 'はい。HQは神戸大学と三宮のちょうど中間、灘区にあります。最寄りの「水道筋3丁目」バス停は徒歩1分で、市バス乗り継ぎなら片道210円で神大正門前まで。阪急王子公園駅・JR摩耶駅も徒歩6〜7分、自転車でも通えます。' },
  { q: '毎月かかる費用はどれくらいですか？', a: '家賃は¥39,000〜47,000。これに共益費¥14,000（水道光熱費・ネット・消耗品込み）を加えて、毎月の支払いは5〜6万円台（部屋により¥53,000〜¥61,000）です。' },
  { q: '入居時の初期費用は？', a: '契約手数料・清掃費とデポジットで計5万円のみ。デポジットは退去時に問題がなければ全額返金します。礼金・仲介手数料はいただきません。' },
  { q: '保証人は必要ですか？', a: '連帯保証人は原則不要です。契約に必要なのは本人確認書類と印鑑、緊急連絡先のみです。' },
  { q: '家具や家電は自分で用意しますか？', a: 'ベッド・布団・机・イス・エアコンは各部屋に備え付け。生活に必要な設備も揃っているので、バッグ1つですぐに暮らし始められます。' },
  { q: '合格前・受験前でも相談できますか？', a: 'もちろんです。まずは見学に来てメンバーと話すだけでも歓迎します。満室のときは空き待ち登録をしておくと、空室が出た際に優先してご案内します。' },
  { q: '短期の入居はできますか？', a: '基本は6ヶ月以上を想定していますが、短期のご相談も可能です（基本家賃より割増の場合あり）。留学や半年だけの滞在で住んだ神大生もいます。' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <Header />

    <!-- Hero -->
    <section class="kuHero">
      <img src="/images/hero.jpg" alt="The Headquarters Kobe" class="kuHeroImg" />
      <div class="kuHeroText">
        <p class="kuKicker">FOR KOBE UNIVERSITY STUDENTS</p>
        <h1>神戸のど真ん中で、<br />学生生活を。</h1>
        <p class="kuLead">
          神戸大学にも、三宮にも、水道筋商店街にも近い。灘区のシェアハウス The Headquarters Kobe。<br />
          学生は、24時間学生じゃないから。
        </p>
        <div class="kuActions">
          <a class="cta" href="/contact">内見・お問い合わせ</a>
          <a class="ctaGhost" href="/rooms">お部屋と家賃を見る</a>
        </div>
      </div>
    </section>

    <main class="kuMain">
      <AvailabilityBanner lang="ja" />

      <!-- 3つの近い -->
      <section class="kuSection">
        <h2 class="kuTitle">大学にも、三宮にも、商店街にも。3つの「近い」</h2>
        <p class="kuIntro">
          神大生に「HQの良かったところ」を聞くと、多くが同じ3つを挙げます。大学に近いこと、神戸の中心・三宮に近いこと、そして足元の商店街で毎日の暮らしがしやすいこと。
        </p>
        <div class="threeGrid">
          <div class="threeCard">
            <div class="threeIcon">🎓</div>
            <h3>大学に近い</h3>
            <p>HQは神戸大学と三宮のちょうど中間。徒歩1分の「水道筋3丁目」バス停から乗り継げば片道210円で神大正門前へ。阪急王子公園駅・JR摩耶駅も徒歩6〜7分、自転車でも通えます。</p>
          </div>
          <div class="threeCard">
            <div class="threeIcon">🌆</div>
            <h3>三宮に近い</h3>
            <p>三ノ宮まで約10分。授業終わりの遊びも、バイト探しも、買い物も映画も。神戸の中心がすぐそこにある学生生活。</p>
          </div>
          <div class="threeCard">
            <div class="threeIcon">🛒</div>
            <h3>商店街が足元</h3>
            <p>活気ある水道筋商店街のど真ん中。安い八百屋やスーパー、炭酸泉の銭湯・灘温泉まで徒歩圏。毎日の生活が歩いて完結します。</p>
          </div>
        </div>
        <blockquote class="kuQuote">
          「交通のアクセスがいい。他の国公立は都心から離れた場所が多いけど、神大は遊びもバイト探しもイベントも映画も行きやすい」
          <cite>— H.G.さん（国際人間科学部）</cite>
        </blockquote>
      </section>

      <!-- 社会的証明 -->
      <section class="kuSection alt">
        <h2 class="kuTitle">神大生が、代々暮らしてきた家</h2>
        <p class="kuIntro">
          国際人間科学部・経済学部・発達科学・文学部（博士）まで、これまで多くの神戸大学の学生・院生がHQで暮らしてきました。卒業生10人に、住んだ理由と本音を聞いています。
        </p>
        <div class="quoteGrid">
          <blockquote class="kuQuote">
            「スーパーや八百屋が近くて生活しやすく、リビングに上がれば誰かとその日あったことを話せる。家具家電付きで、旅行に行くようなバッグ1つで生活を始められたのが決め手でした」
            <cite>— Yさん（国際人間科学部）</cite>
          </blockquote>
          <blockquote class="kuQuote">
            「家具もいらず生活費も抑えられて、価値観の違う人と暮らすからこそ考えが広がる。マジで迷ったら、住んでみたほうがいい」
            <cite>— K.S.さん（経済学部）</cite>
          </blockquote>
        </div>
        <a class="kuLink" href="/blog/bulk/kobe-university-share-house-voices/">元住人10人のインタビューを読む →</a>
      </section>

      <!-- 費用 -->
      <section class="kuSection">
        <h2 class="kuTitle">家具付き・月5万円台・初期費用も5万円</h2>
        <div class="feeGrid">
          <div class="feeCard">
            <div class="feeLabel">毎月</div>
            <div class="feeMain">家賃 ¥39,000〜47,000</div>
            <div class="feeSub">＋ 共益費¥14,000（水道光熱費・ネット・消耗品込み）<br /><strong>= 月々5〜6万円台</strong></div>
          </div>
          <div class="feeCard">
            <div class="feeLabel">入居時</div>
            <div class="feeMain">初期費用 計5万円のみ</div>
            <div class="feeSub">契約手数料・清掃費2.5万円 ＋ 退去時に返金されるデポジット2.5万円。<strong>礼金・仲介手数料は0円。</strong></div>
          </div>
          <div class="feeCard">
            <div class="feeLabel">安心</div>
            <div class="feeMain">保証人 原則不要</div>
            <div class="feeSub">家具家電（ベッド・布団・机・イス・エアコン）付き。バッグ1つで入居できます。</div>
          </div>
        </div>
        <p class="kuNote">ワンルームを借りて家具・家電を揃え、礼金・仲介手数料を払うより、始めやすく、毎月の負担も軽く。</p>
      </section>

      <!-- 勉強も暮らしも -->
      <section class="kuSection alt">
        <h2 class="kuTitle">勉強も、暮らしも。</h2>
        <div class="featGrid">
          <div class="featItem"><h3>個室にロフトベッド＋勉強机</h3><p>眠る場所と勉強する場所を分けられる、集中できる自分の部屋。</p></div>
          <div class="featItem"><h3>広いリビングと揃ったキッチン</h3><p>自炊で食費を抑えつつ、誰かと食卓を囲める。ひとりで抱え込まない暮らし。</p></div>
          <div class="featItem"><h3>屋上でBBQ・プール</h3><p>授業や研究の合間の息抜き。摩耶山・六甲もすぐそば。</p></div>
          <div class="featItem"><h3>世界中の住人と国際交流</h3><p>国際色ゆたかな神大と相性よく、英語を使う機会も日常に。「国内留学」感覚で。</p></div>
        </div>
      </section>

      <!-- 保護者の方へ -->
      <section class="kuSection parents">
        <h2 class="kuTitle">保護者の方へ</h2>
        <p>
          はじめての一人暮らしでも安心して送り出していただけるよう——連帯保証人は原則不要、初期費用は計5万円、家具家電も付いています。管理者が常に住人とつながり、困りごとにはすぐ対応します。内見時にはリビングでゆっくりお話しし、どんな暮らしかを実際に見ていただけます。
        </p>
      </section>

      <!-- FAQ -->
      <section class="kuSection">
        <h2 class="kuTitle">よくある質問</h2>
        <div class="faqList">
          {faqs.map((f) => (
            <details class="faqItem">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- 関連ブログ -->
      {relatedPosts.length > 0 && (
        <section class="kuSection alt">
          <h2 class="kuTitle">神大生の暮らし、もっと読む</h2>
          <div class="grid">
            {relatedPosts.map((post) => (
              <a class="card linkCard" href={`/blog/${post.id}/`}>
                {post.img && <img src={post.img} alt={post.title} class="cardThumb" />}
                <div class="cardBody"><h3>{post.title}</h3></div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- 最終CTA -->
      <section class="kuFinal">
        <h2>まずは、見に来てください。</h2>
        <p>気になったら一度、遊びに来てメンバーと話すだけでも大歓迎です。今のお部屋の空き状況はお問い合わせください。満室のときは空き待ち登録を。</p>
        <div class="kuActions center">
          <a class="cta" href="/contact">内見・お問い合わせ</a>
          <a class="ctaGhost" href="/waitlist">空き待ち登録</a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .kuHero { position: relative; }
  .kuHeroImg {
    width: 100%; display: block;
    aspect-ratio: 1189 / 438; object-fit: cover; object-position: center;
    filter: brightness(0.72);
  }
  .kuHeroText {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    justify-content: center; align-items: center; text-align: center;
    padding: 24px; color: #fff;
  }
  .kuKicker { margin: 0 0 12px; letter-spacing: .14em; font-size: 12px; color: rgba(255,255,255,.85); }
  .kuHeroText h1 { margin: 0 0 16px; color: #fff; font-size: clamp(30px, 5vw, 52px); line-height: 1.12; text-shadow: 0 6px 24px rgba(0,0,0,.55); }
  .kuLead { margin: 0 auto 22px; max-width: 60ch; font-size: clamp(15px, 2.2vw, 18px); color: rgba(255,255,255,.92); text-shadow: 0 2px 12px rgba(0,0,0,.4); }
  .kuActions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .kuActions.center { justify-content: center; }
  .cta, .ctaGhost { display: inline-block; padding: 13px 22px; border-radius: 12px; text-decoration: none; font-weight: 700; }
  .cta { background: var(--accent); color: #fff; }
  .cta:hover { filter: brightness(1.08); }
  .ctaGhost { border: 2px solid rgba(255,255,255,.85); color: #fff; background: rgba(0,0,0,.2); }
  .kuMain { max-width: 1080px; margin: 0 auto; padding: 8px 24px 24px; }

  .kuSection { padding: 40px 28px; margin-top: 28px; border-radius: 24px; }
  .kuSection.alt { background: linear-gradient(180deg, rgba(var(--gray-light), .6), rgba(var(--gray-light), .2)); }
  .kuSection.parents { background: #f0fdf4; border: 1px solid #bbf7d0; }
  .kuTitle { margin: 0 0 14px; font-size: clamp(20px, 3vw, 26px); }
  .kuIntro { margin: 0 0 22px; color: rgb(var(--gray-dark)); max-width: 68ch; }

  .threeGrid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .threeCard { background: #fff; border-radius: 16px; padding: 22px 20px; box-shadow: var(--box-shadow); }
  .threeIcon { font-size: 30px; }
  .threeCard h3 { margin: 8px 0; font-size: 17px; }
  .threeCard p { margin: 0; font-size: 14px; color: rgb(var(--gray)); line-height: 1.65; }

  .kuQuote { margin: 22px 0 0; padding: 16px 20px; background: #fff; border-left: 4px solid var(--accent); border-radius: 8px; font-size: 15px; line-height: 1.7; box-shadow: var(--box-shadow); }
  .kuQuote cite { display: block; margin-top: 8px; font-size: 13px; color: rgb(var(--gray)); font-style: normal; }
  .quoteGrid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .kuLink { display: inline-block; margin-top: 18px; font-weight: 700; color: var(--accent); text-decoration: none; }
  .kuLink:hover { text-decoration: underline; }

  .feeGrid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .feeCard { background: #fff; border-radius: 16px; padding: 22px 20px; box-shadow: var(--box-shadow); }
  .feeLabel { font-size: 11px; font-weight: 700; letter-spacing: .12em; color: var(--accent); text-transform: uppercase; }
  .feeMain { font-size: 19px; font-weight: 700; margin: 8px 0 8px; color: rgb(var(--gray-dark)); }
  .feeSub { font-size: 13.5px; color: rgb(var(--gray)); line-height: 1.65; }
  .kuNote { margin: 18px 0 0; font-size: 14px; color: rgb(var(--gray)); }

  .featGrid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .featItem { background: #fff; border-radius: 14px; padding: 18px 20px; box-shadow: var(--box-shadow); }
  .featItem h3 { margin: 0 0 6px; font-size: 16px; }
  .featItem p { margin: 0; font-size: 14px; color: rgb(var(--gray)); line-height: 1.6; }

  .faqList { display: grid; gap: 10px; }
  .faqItem { background: #fff; border-radius: 12px; padding: 4px 20px; box-shadow: var(--box-shadow); }
  .faqItem summary { cursor: pointer; padding: 14px 0; font-weight: 700; font-size: 15px; }
  .faqItem p { margin: 0 0 14px; font-size: 14px; color: rgb(var(--gray)); line-height: 1.7; }

  .grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .card { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: var(--box-shadow); }
  .cardThumb { width: 100%; height: 150px; object-fit: cover; display: block; }
  .cardBody { padding: 14px 18px; }
  .cardBody h3 { font-size: 14px; margin: 0; line-height: 1.5; }
  .linkCard { text-decoration: none; color: inherit; transition: transform .15s ease, box-shadow .15s ease; }
  .linkCard:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,0,0,.12); }

  .kuFinal { margin-top: 28px; padding: 48px 28px; border-radius: 24px; text-align: center; background: linear-gradient(135deg, rgba(var(--accent-rgb, 51,85,204), .1), rgba(var(--gray-light), .5)); }
  .kuFinal h2 { margin: 0 0 12px; font-size: clamp(22px, 3.4vw, 30px); }
  .kuFinal p { margin: 0 auto 22px; max-width: 60ch; color: rgb(var(--gray-dark)); }
  .kuFinal .cta { background: var(--accent); }
  .kuFinal .ctaGhost { border-color: rgba(var(--gray), 45%); color: rgb(var(--gray-dark)); background: #fff; }
</style>
